:4000 {
	# Live apps — served straight from filesystem, no process needed
	handle_path /apps/* {
		root * apps
		try_files {path} {path}/index.html
		file_server
	}

	# Drizzle Studio
	handle_path /studio/* {
		reverse_proxy localhost:4983
	}

	# API service
	handle_path /api/* {
		reverse_proxy localhost:3001
	}

	# Claude editing service + chat UI
	handle_path /claude/* {
		reverse_proxy localhost:3002
	}

	# JWKS
	handle /.well-known/* {
		reverse_proxy localhost:3001
	}

	# Default → dashboard shell
	handle {
		root * services/dashboard/public
		try_files {path} /index.html
		file_server
	}
}
